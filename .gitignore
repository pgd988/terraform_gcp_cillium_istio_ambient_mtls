# Local .terraform directories
**/.terraform/
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data sensitive.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore execution plan files
*.tfplan
*.plan

# Ignore editor/OS backup and generated files
*.swp
*.swo
*~
.DS_Store
.idea/
.vscode/
*.log
.agents/

